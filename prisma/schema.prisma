// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "client"
}

datasource db {
  provider = "postgresql"
}

model ContactMessage {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  trek      String?
  message   String
  createdAt DateTime @default(now())
}

model Region {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String
  image       String   @default("")
  createdAt   DateTime @default(now())
  treks       Trek[]
}

model Trek {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  difficulty  String
  durationDays Int
  price       Float
  altitude    String   @default("")
  season      String   @default("")
  highlights  String   @default("") // pipe-separated string
  itinerary   String   @default("") // pipe-separated day entries
  images      String   @default("") // pipe-separated image URLs
  regionId    String
  region      Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Video {
  id        String   @id @default(uuid())
  title     String
  location  String
  duration  String
  cover     String
  src       String
  createdAt DateTime @default(now())
}

model ServiceCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String
  image       String   @default("")
  createdAt   DateTime @default(now())
  services    Service[]
}

model Service {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  description  String
  durationDays Int?
  price        Float
  itinerary    String   @default("") // pipe-separated day entries
  images       String   @default("") // pipe-separated image URLs
  categoryId   String
  category     ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model TeamMember {
  id        String   @id @default(uuid())
  name      String
  role      String
  bio       String
  image     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model InterviewApplication {
  id         String   @id @default(uuid())
  name       String
  email      String
  phone      String
  position   String   // Lead Guide, Assistant Guide, Office Staff, etc.
  experience String   // Years of experience
  message    String   @db.Text
  createdAt  DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  name      String
  email     String
  country   String   @default("")
  rating    Int      // 1 to 5 stars
  trip      String   // trek / service name
  title     String   @default("")
  review    String   @db.Text
  photoUrl  String   @default("") // optional uploaded photo
  approved  Boolean  @default(false) // admin can approve before showing publicly
  createdAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
