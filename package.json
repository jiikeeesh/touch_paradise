{
  "name": "touch_paradise",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:worker": "prisma generate && node -e \"const fs=require('fs');const p='node_modules/next/dist/compiled/@vercel/og';if(fs.existsSync(p)){fs.writeFileSync(p+'/index.edge.js','module.exports={ImageResponse:class{}}');try{fs.unlinkSync(p+'/resvg.wasm')}catch(e){}}\" && npx @opennextjs/cloudflare build --minify",
    "deploy": "npm run build:worker && npx @opennextjs/cloudflare deploy",
    "preview": "npm run build:worker && npx wrangler dev",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "aws4fetch": "^1.0.20",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "pg": "^8.20.0",
    "pg-cloudflare": "^1.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.84.0"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
